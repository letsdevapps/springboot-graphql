
# Tipos principais
type Client {
    id: ID
    name: String
    email: String
}

# Queries (consultas)
type Query {
    message: String
    clients: [Client]
    client(id: ID): Client
}

# Mutations (operações que alteram dados)
type Mutation {
    createClient(name: String, email: String): Client
    deleteClient(id: ID): Boolean
    updateClient(id: ID, name: String, email: String): Client
}